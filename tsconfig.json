{
  "compilerOptions": {
    "target": "es2022",
    "rootDir": "./src",
    "outDir": "./build",

    "module": "commonjs",
    "moduleResolution": "node",

    "esModuleInterop": true,

    "sourceMap": true,
    // declaration types files are generated for other projects to use this codebase as a library
    "declaration": false, // Generates .d.ts files for use as a library

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noUnusedParameters": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
